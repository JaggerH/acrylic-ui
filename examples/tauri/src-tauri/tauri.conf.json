{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "acrylic-playground",
  "version": "0.1.0",
  "identifier": "dev.acrylic.playground",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "acrylic-ui · vibrancy playground",
        "width": 1100,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
